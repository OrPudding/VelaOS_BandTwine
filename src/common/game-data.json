          "path": "/common/images/forest.png",
          "width": 300
        }
      },
      "links": [
        {
          "text": "向左探索（消耗20分钟）",
          "target": "forest_left1",
          "actions": [
            {
              "type": "add",
              "target": "var.show.time.value",
              "value": -20
            }
          ]
        },
